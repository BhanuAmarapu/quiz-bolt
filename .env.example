# Shared runtime settings
NODE_ENV=production
SERVER_PORT=5000
PAYMENT_SERVICE_PORT=5001

# Server
MONGO_URI=mongodb://admin:password@localhost:27017/quiz_platform?authSource=admin
JWT_SECRET=your_super_secret_jwt_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key
REDIS_URL=redis://localhost:6379
CLIENT_URL=http://localhost:5173,http://yourdomain.com
PAYMENT_SERVICE_URL=http://localhost:5001

# Client
VITE_API_URL=/api

# Payment Service
DATABASE_URL=mongodb://admin:password@localhost:27017/quiz_platform?authSource=admin
RAZORPAY_KEY_ID=rzp_test_xxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
WEBHOOK_SECRET=your_webhook_signature_secret
CORS_ORIGIN=http://localhost:5173,http://yourdomain.com
JWT_SECRET=your_super_secret_jwt_key
